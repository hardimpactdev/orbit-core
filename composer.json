{
    "$schema": "https://getcomposer.org/schema.json",
    "name": "hardimpactdev/orbit-core",
    "description": "Shared Orbit core contracts and helpers.",
    "keywords": [
        "laravel",
        "orbit"
    ],
    "license": "MIT",
    "type": "library",
    "require": {
        "php": "^8.5",
        "illuminate/support": "^12.0 || ^13.0"
    },
    "require-dev": {
        "laravel/pint": "^1.29",
        "pestphp/pest": "^4.6",
        "phpstan/phpstan": "^2.1",
        "rector/rector": "^2.3"
    },
    "autoload": {
        "psr-4": {
            "Orbit\\Core\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Orbit\\Core\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "analyse": "vendor/bin/phpstan analyse --memory-limit=512M",
        "format": "vendor/bin/pint",
        "rector": "vendor/bin/rector process",
        "test": "vendor/bin/pest --compact"
    },
    "extra": {
        "laravel": {
            "providers": [
                "Orbit\\Core\\OrbitCoreServiceProvider"
            ]
        }
    },
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "rector/rector": true
        },
        "sort-packages": true
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "version": "0.1.119"
}
